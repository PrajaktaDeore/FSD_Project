# Django
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=django-insecure-dev-key-change-me

# Required when DJANGO_DEBUG=0 (comma-separated)
# DJANGO_ALLOWED_HOSTS=milkybasket.duckdns.org,apimilkybasket.duckdns.org

# Behind nginx/https
# DJANGO_SECURE_SSL_REDIRECT=1
# DJANGO_SESSION_COOKIE_SECURE=1
# DJANGO_CSRF_COOKIE_SECURE=1

# CORS/CSRF (recommended for production)
# DJANGO_CORS_ALLOWED_ORIGINS=https://milkybasket.duckdns.org
# DJANGO_CSRF_TRUSTED_ORIGINS=https://milkybasket.duckdns.org
