# Backend base URL for API calls (no trailing slash).
# - Dev default (if unset): http://localhost:8000
# - Prod default (if unset): same-origin (empty baseURL)
VITE_API_BASE_URL=http://localhost:8000

# Optional API prefix (useful when nginx proxies only /api/* to Django).
# Example for your deployment:
# VITE_API_BASE_URL=https://milkybasket.duckdns.org
# VITE_API_PREFIX=/api
# (no trailing slash)
