# Production example for Vite build (values are baked into the bundle at build time)

# Same-origin is recommended when nginx serves the frontend on the same domain.
# Leave VITE_API_BASE_URL unset and only use the prefix:
VITE_API_PREFIX=/api

# If frontend and backend are on different domains, set the base URL:
# VITE_API_BASE_URL=https://milkybasket.duckdns.org
